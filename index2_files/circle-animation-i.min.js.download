jQuery(window).on("load", function () {
    $("#platform_hero").fadeOut("slow"),
        console.log("loaded!"),
        lottie.loadAnimation({
            container: document.getElementById("problem"),
            renderer: "svg",
            loop: !0,
            autoplay: !0,
            path: `${templateUrl}/new-assets/json/mu-internal.json`,
        });
});
